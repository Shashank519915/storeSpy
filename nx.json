{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/packages/ts-config/tsconfig.strict.json",
      "{workspaceRoot}/packages/proto/buf.yaml"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts"
    ],
    "go": ["{projectRoot}/**/*.go", "{projectRoot}/go.mod", "{projectRoot}/go.sum"],
    "python": [
      "{projectRoot}/**/*.py",
      "{projectRoot}/pyproject.toml",
      "{projectRoot}/uv.lock"
    ],
    "typescript": [
      "{projectRoot}/**/*.{ts,tsx}",
      "{projectRoot}/tsconfig.json",
      "{projectRoot}/package.json"
    ],
    "terraform": ["{projectRoot}/**/*.{tf,tfvars}"],
    "helm": ["{projectRoot}/**/*.{yaml,yml,tpl}"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js",
      "options": {
        "analyzeSourceFiles": true
      }
    }
  ],
  "defaultBase": "main"
}
